<Window x:Class="MediaRake.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MediaRake" Height="700" Width="1100"
        MinHeight="500" MinWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <Border Grid.Column="0" Background="#1E1E2E">
            <DockPanel>
        
                <TextBlock DockPanel.Dock="Top" 
                           Text="MediaRake"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="16,16,16,8"/>

                <Button DockPanel.Dock="Bottom"
                        Content="+ New List"
                        Margin="16,8,16,16"
                        Padding="0,10"
                        Background="#6C63FF"
                        Foreground="White"
                        BorderThickness="0"
                        Click="NewList_Click"/>

                <ListBox ItemsSource="{Binding Lists}"
                         SelectedItem="{Binding SelectedList}"
                         Background="Transparent"
                         BorderThickness="0"
                         Margin="8,0,8,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"
                                       Foreground="White"
                                       Padding="8,6"
                                       FontSize="13"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
        
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Background="#13131F">
            <DockPanel Margin="16">
        
                <!-- List title -->
                <TextBlock DockPanel.Dock="Top"
                           Text="{Binding SelectedList.Name}"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,16"/>

                <!-- Add item button -->
                <Button DockPanel.Dock="Top"
                        Content="+ Add Item"
                        HorizontalAlignment="Left"
                        Padding="16,8"
                        Margin="0,0,0,16"
                        Background="#6C63FF"
                        Foreground="White"
                        BorderThickness="0"
                        Click="AddItem_Click"/>

                <!-- Items list -->
                <ListBox ItemsSource="{Binding SelectedList.Items}"
                         Background="Transparent"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Title}"
                                       Foreground="White"
                                       Padding="8,6"
                                       FontSize="13"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </DockPanel>
        </Border>
        
    </Grid>
</Window>